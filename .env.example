SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=anon_key
SUPABASE_SECRET_KEY=secret_key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
CLOVER_APP_ID=your_clover_app_id
CLOVER_SECRET_CODE=your_clover_app_secret
CLOVER_URL=https://apisandbox.dev.clover.com
CLOVER_OAUTH_URL=https://sandbox.dev.clover.com
CLOVER_WEBHOOK_AUTH_CODE=your_clover_webhook_auth_code
CLOVER_TOKEN_ENCRYPTION_KEY=change_me_to_a_long_random_secret

# Marketing site — "Become a vendor" application emails (Resend)
RESEND_API_KEY=your_resend_api_key
VENDOR_APPLICATION_TO_EMAIL=applications@your-domain.com
# Optional; defaults to Resend's shared onboarding@resend.dev sender for testing.
# Use an address on a domain you've verified in Resend for production.
VENDOR_APPLICATION_FROM_EMAIL=onboarding@resend.dev
