{
  "name": "@forest-city-vault/infrastructure-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "test": "node --import tsx --test src/**/*.spec.ts",
    "db:generate:drizzle-schema": "tsx scripts/generate-drizzle-flat-schema.ts",
    "db:generate": "pnpm db:generate:drizzle-schema && drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@effect/sql": "^0.51.1",
    "@effect/sql-drizzle": "^0.50.0",
    "@effect/sql-pg": "^0.52.1",
    "@forest-city-vault/core-config": "workspace:*",
    "@forest-city-vault/core-domain": "workspace:*",
    "@forest-city-vault/application-core": "workspace:*",
    "@forest-city-vault/domain": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "effect": "^3.21.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@effect/experimental": "0.60.0",
    "@electric-sql/pglite": "^0.4.6",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.0",
    "pg": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5"
  }
}
