{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["src/**/*", "drizzle.config.ts", "scripts"],
  "exclude": ["node_modules", "dist"]
}
